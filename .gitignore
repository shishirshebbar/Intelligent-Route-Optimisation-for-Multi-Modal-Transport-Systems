.env*
# Ignore Python cache files
__pycache__/

# Ignore files with extension .region
*.region

# Ignore files named region.<ext> (e.g. region.json, region.yaml)
region.*

# Ignore any file or directory whose name contains "region"
*region*

# Ignore any directory named "region" anywhere in the tree
region/
**/region/

docs/ieee_conference_paper.tex
docs/revised_research paper.tex
